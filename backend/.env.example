# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vehicle_erp

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# WhatsApp (invoice/quotation/loan messages & share links)
# mock | twilio | waba (waba not implemented)
WHATSAPP_PROVIDER=mock
# Optional: separate secret for JWT share links (defaults to JWT_SECRET)
# SHARE_SECRET=
# Public URL used in WhatsApp share links (defaults to CORS_ORIGIN)
# PUBLIC_APP_URL=http://localhost:5173

# Twilio WhatsApp (when WHATSAPP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 or whatsapp:+... — also accepts TWILIO_WHATSAPP_NUMBER
TWILIO_WHATSAPP_FROM=

# 2Factor SMS
TWO_FACTOR_API_KEY=

# ── Taxpro GSP E-Invoice & E-Way Bill ─────────────────
# Set to 'production' when live, defaults to 'sandbox'
TAXPRO_ENV=sandbox
# Standard TPS GSP credentials
TAXPRO_CLIENT_ID=
TAXPRO_CLIENT_SECRET=
TAXPRO_USERNAME=
TAXPRO_PASSWORD=
# Your business GSTIN registered on Taxpro
TAXPRO_GSTIN=
