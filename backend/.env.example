# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vehicle_erp

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# WhatsApp: messages open in the WhatsApp app/web (wa.me) with prefilled text; share/PDF links use JWT.
# Optional: separate secret for JWT share links (defaults to JWT_SECRET)
# SHARE_SECRET=
# Public URL used in WhatsApp share links (defaults to CORS_ORIGIN)
# PUBLIC_APP_URL=http://localhost:5173

# 2Factor SMS
TWO_FACTOR_API_KEY=

# ── Masters India E-Invoice (IRN) & E-Way Bill ─────────────────
# sandbox | production — API host: sandb-api.mastersindia.co vs router.mastersindia.co
MASTERS_INDIA_ENV=sandbox
# Profile API key (Masters UI → API Keys). Sandbox IRN usually also needs a login token:
MASTERS_INDIA_API_KEY=
# Portal username/password — required for most sandbox calls (token-auth → Authorization header).
MASTERS_INDIA_USERNAME=
MASTERS_INDIA_PASSWORD=
# api_key_only = only api_key header (often fails on sandbox with "access token was not found").
# bearer_and_api_key = api_key + Authorization: Bearer <api_key> (default). Best: use USERNAME+PASSWORD+API_KEY.
MASTERS_INDIA_OPAQUE_AUTH=bearer_and_api_key
# jwt | bearer — prefix for token-auth access token (try bearer if JWT still fails).
# MASTERS_INDIA_TOKEN_SCHEME=jwt
# MASTERS_INDIA_API_AUTH_MODE=authorization_jwt
