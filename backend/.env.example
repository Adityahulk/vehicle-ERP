# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vehicle_erp

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# WhatsApp: messages open in the WhatsApp app/web (wa.me) with prefilled text; share/PDF links use JWT.
# Optional: separate secret for JWT share links (defaults to JWT_SECRET)
# SHARE_SECRET=
# Public URL used in WhatsApp share links (defaults to CORS_ORIGIN)
# PUBLIC_APP_URL=http://localhost:5173

# 2Factor SMS
TWO_FACTOR_API_KEY=

# ── TaxPro GSP — E-Invoice (IRN) & E-Way Bill (CharteredInfo) ───────────────
# sandbox | production — default API host: gstsandbox.charteredinfo.com vs einvapi.charteredinfo.com
TAXPRO_ENV=sandbox
# Optional: override base URL (e.g. if TaxPro gives a different endpoint)
# TAXPRO_API_HOST=https://gstsandbox.charteredinfo.com

# ASP credentials (from TaxPro / Postman)
TAXPRO_ASPID=
TAXPRO_PASSWORD=

# E-Invoice auth: GET /eivital/dec/v1.04/auth (Gstin = seller; use company GSTIN per request)
TAXPRO_EINV_USER_NAME=
TAXPRO_EINV_PASSWORD=

# E-Way bill auth: GET /ewaybillapi/dec/v1.03/auth?action=ACCESSTOKEN
# If the same portal user works for both, set TAXPRO_USER_NAME once and omit the specific *_USER_NAME vars.
# TAXPRO_USER_NAME=
TAXPRO_EWB_USER_NAME=
TAXPRO_EWB_PASSWORD=

# QR image size for IRN response (query param QrCodeSize)
TAXPRO_QR_CODE_SIZE=250

# Rarely needed: Postman defaults are GENEWAYBILL / CANEWB
# TAXPRO_EWB_GEN_ACTION=GENEWAYBILL
# TAXPRO_EWB_CANCEL_ACTION=CANEWB
