# ── Database ──────────────────────────────
DB_USER=erp_user
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_NAME=vehicle_erp

# ── Auth ──────────────────────────────────
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── App ───────────────────────────────────
# Set this to http://YOUR_DROPLET_IP
CORS_ORIGIN=http://64.227.140.244
MAX_FILE_SIZE=5242880

# ── Adminer (optional DB UI in browser) ───
# Binds Adminer to this host IP on the server. Use 127.0.0.1 so it is not exposed on the public IP.
# ADMINER_BIND=127.0.0.1
# ADMINER_PORT=8080
# To expose on all interfaces (not recommended): ADMINER_BIND=0.0.0.0

# ── Twilio WhatsApp (optional) ───────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ── 2Factor SMS (optional) ───────────────
TWO_FACTOR_API_KEY=

# ── ClearTax (E-Invoice / E-Way Bill) ────
CLEARTAX_ENV=sandbox
CLEARTAX_AUTH_TOKEN=
CLEARTAX_GSTIN=
